{
//    "layer": "top",
    "position": "top",
    "spacing": 0,
    "margin-top": 0,
    "margin-left": 0,
    "margin-right": 0,

    "modules-left": [
        "sway/workspaces"
    ],

    "modules-center": [
        "clock"
    ],

    "modules-right": [
        "tray",
        "network",
        "pulseaudio",
    ],

    "wlr/taskbar": {
        "format": "{icon}",
        "on-click": "activate",
        "on-click-right": "fullscreen",
        "icon-theme": "WhiteSur",
        "icon-size": 25,
        "tooltip-format": "{title}"
    },

    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{icon}",
        "format-icons": {
            "1": "ΎΚρ",
            "2": "ΎΕκ",
            "3": "ΎΕι",
            "9": "ΎΒ╡",
            "10": "ΎΗ╝",
        },
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "9": [],
            "10": [],
        }
    },

    "tray": {
        "spacing": 10
    },

    "clock": {
        "format": "{:%I:%M %p - %a, %d %b %Y}"
    },
    
    "network": {
        "format-wifi" : "{icon}",
        "format-icons": ["≤░νψ","≤░νθ","≤░νλ","≤░νξ","≤░νρ"],
        "format-ethernet": "ΎΒ╛",
        "format-disconnected" : "≤░νχ",
	      "interval": 5,
    },

    "pulseaudio": {
        "scroll-step": 5,
        "max-volume": 150,
        "format": "{icon} {volume}%",
        "format-bluetooth": "≤░Γ░",
        "nospacing": 1,
        "format-muted": "≤░ζθ",
        "format-icons": {
            "headphone": "ΎΑξ",
            "default": ["ΎΑο","ΎΑπ" ,"ΎΑρ "]
        },
        "on-click": "pamixer -t",
    },

    "battery": {
        "format": "{icon} {capacity}%",
        "format-icons": {
            "charging": [
                "≤░λε",
                "≤░ΓΗ",
                "≤░ΓΘ",
                "≤░ΓΙ",
                "≤░λζ",
                "≤░ΓΚ",
                "≤░λη",
                "≤░ΓΛ",
                "≤░ΓΜ",
                "≤░ΓΖ"
            ],
            "default": [
                "≤░Β║",
                "≤░Β╗",
                "≤░Β╝",
                "≤░Β╜",
                "≤░Β╛",
                "≤░Β┐",
                "≤░ΓΑ",
                "≤░ΓΒ",
                "≤░ΓΓ",
                "≤░Β╣"
            ]
        },
        "format-full": "Charged ΎΔπ",
        "interval": 5,
        "states": {
            "warning": 20,
            "critical": 10
        },
        "tooltip": false
    },
}
