{
    "layer": "top",
    "position": "top",
    "height": 35,
    "margin-top": 10,
    "margin-bottom":5,
    "margin-left": 10,
    "margin-right": 10,

    // Choose the order of the modules

    "modules-left":["custom/launcher", "wlr/taskbar"],
    "modules-right":["mpris",  "idle_inhibitor", "pulseaudio", "cpu", "memory", "backlight", "keyboard-state", "network", "tray", "clock", "custom/power"],

    // Modules configuration
    "mpris": {
        "format": "{player_icon} {dynamic}",
        "format-paused": "{status_icon} {dynamic}",
        "on-scroll-up": "playerctl next",
        "on-scroll-down": "playerctl previous",
        "player-icons": {
