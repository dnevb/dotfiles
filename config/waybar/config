           "mpv": "­¤ÄĄ"
        },
        "status-icons": {
          "paused": "¾░Åż"
        }
    },
    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 20,
        "icon-theme": "Star",
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close",
        "on-click-right": "minimize"
    },
    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": "’ä£ {name} {icon}",
        "format-icons": {
            "locked": "’ĆŻ",
            "unlocked": "’é£"
